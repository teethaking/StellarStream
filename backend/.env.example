# Database Configuration (required for Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellarstream

# Stellar Network Configuration
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Configuration
CONTRACT_ID=YOUR_CONTRACT_ID_HERE
V1_CONTRACT_ID=YOUR_LEGACY_V1_CONTRACT_ID_HERE
NEBULA_CONTRACT_ID=YOUR_NEBULA_V2_CONTRACT_ID_HERE

# Service Configuration
POLL_INTERVAL_MS=5000
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Redis — required for distributed rate limiting across backend clusters
# Global limit: 100 req/min | Sensitive endpoints (/auth/challenge, /webhook/register): 5 req/min
REDIS_URL=redis://localhost:6379

# Optional: Logging
LOG_LEVEL=info

# Security Configuration
FRONTEND_URL=http://localhost:5173,http://localhost:3000
NODE_ENV=development

SENTRY_DSN=your-sentry-dsn-here

# Admin API — used by requireAdmin middleware to protect /api/v2/admin/* routes
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your-strong-random-admin-key-here

# Notifications (Discord / Telegram stream alerts)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Discord webhooks are stored per-user in the NotificationSubscription table


JWT_SECRET=your-strong-random-secret-here

# Gas Tank / Burn Rate Configuration
# Soroban rent fee per 1 KB per ledger (stroops). Default: 1000
# GAS_TANK_RENT_FEE_PER_1KB_PER_LEDGER=1000
# Estimated on-chain stream entry size in bytes. Default: 200
# GAS_TANK_STREAM_SIZE_BYTES=200

# Dust Filter Configuration
# Minimum stream value in USD to exclude from analytics (default: $0.10)
MIN_VALUE_USD=0.10
