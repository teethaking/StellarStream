// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Mirrors the Stream state from the Soroban smart contract
model Stream {
  id                 String       @id @default(cuid())
  streamId           String?      @unique // Contract-level Stream ID
  txHash             String       @unique
  version            Int          @default(1)
  sender             String
  receiver           String
  contractId         String?      @map("contract_id")
  tokenAddress       String?
  amount             String // Store as string to handle large numbers safely
  duration           Int?
  status             StreamStatus @default(ACTIVE)
  withdrawn          String?      @default("0")
  legacy             Boolean      @default(false) // true = originated from V1 contract
  migrated           Boolean      @default(false) // true = V1 stream superseded by V2
  isPrivate          Boolean      @default(false)
  yieldEnabled       Boolean      @default(false) @map("yield_enabled")
  vaultContractId    String?
  vaultShareBalance  String?
  vaultRatioScale    String?
  accruedInterest    String       @default("0")
  lastYieldAccrualAt DateTime?
  isDust             Boolean      @default(false) // true = below MIN_VALUE_USD threshold
  affiliateId        String? // Affiliate who referred this stream (0.5% commission)
  createdAt          DateTime     @default(now())

  @@index([sender])
  @@index([receiver])
  @@index([streamId])
  @@index([contractId])
  @@index([legacy])
  @@index([yieldEnabled, status])
  @@index([isDust])
  @@index([affiliateId])
}

model ContractEvent {
  id             String   @id @default(cuid())
  eventId        String   @unique @map("event_id")
  contractId     String   @map("contract_id")
  txHash         String   @map("tx_hash")
  eventType      String   @map("event_type")
  eventIndex     Int      @default(0) @map("event_index")
  ledgerSequence Int      @map("ledger_sequence")
  ledgerClosedAt String?  @map("ledger_closed_at")
  topicXdr       String[] @default([]) @map("topic_xdr")
  valueXdr       String   @map("value_xdr")
  decodedJson    Json     @map("decoded_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([txHash, eventIndex])
  @@index([contractId, ledgerSequence])
  @@index([eventType])
  @@index([txHash])
}

// Token prices for leaderboard volume calculations
model TokenPrice {
  tokenAddress String   @id
  symbol       String
  decimals     Int      @default(7)
  priceUsd     Float    @default(0)
  updatedAt    DateTime @updatedAt
}

// Registered Webhooks for external notifications
model Webhook {
  id          String   @id @default(cuid())
  url         String   @unique
  description String?
  eventType   String   @default("*") // "*" = all events, or specific: create_stream, withdraw, cancel
  secretKey   String // HMAC secret for signing payloads
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventType])
  @@index([isActive])
}

// Webhook delivery attempts for retry logic
model WebhookDelivery {
  id          String    @id @default(cuid())
  webhookId   String
  eventType   String
  payload     Json
  status      String    @default("pending") // pending, success, failed
  attempts    Int       @default(0)
  maxRetries  Int       @default(5)
  nextRetryAt DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([webhookId, status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

// Tracks the last synced blockchain ledger sequence
model SyncState {
  id                 Int @id @default(1)
  lastLedgerSequence Int @default(0)
}

// Audit log for all protocol events
model EventLog {
  id             String   @id @default(cuid())
  eventType      String // create, withdraw, cancel
  streamId       String
  txHash         String
  eventIndex     Int      @default(0) // Position of event within the transaction
  ledger         Int
  ledgerClosedAt String
  sender         String?
  receiver       String?
  amount         BigInt?
  metadata       String? // JSON string
  createdAt      DateTime @default(now())

  @@unique([txHash, eventIndex])
  @@index([streamId])
  @@index([eventType])
  @@index([createdAt])
  @@index([ledger])
}

// Monthly snapshots of stream states
model StreamSnapshot {
  id              String       @id @default(cuid())
  streamId        String
  sender          String
  receiver        String
  tokenAddress    String
  amountPerSecond BigInt
  totalAmount     BigInt
  status          StreamStatus
  snapshotMonth   String // YYYY-MM
  createdAt       DateTime     @default(now())

  @@unique([streamId, snapshotMonth])
  @@index([streamId])
  @@index([snapshotMonth])
}

// Archived event logs (older than 3 months)
model StreamArchive {
  id             String   @id @default(cuid())
  eventType      String
  streamId       String
  txHash         String
  ledger         Int
  ledgerClosedAt String
  sender         String?
  receiver       String?
  amount         BigInt?
  metadata       String?
  createdAt      DateTime
  archivedAt     DateTime @default(now())

  @@index([streamId])
  @@index([createdAt])
}

// Generic bridge activity log for cross-chain operations
model BridgeLog {
  id          String    @id @default(cuid())
  bridge      String
  eventType   String
  sourceChain String
  targetChain String
  sourceAsset String
  targetAsset String?
  amount      String
  sender      String?
  recipient   String
  txHash      String    @unique
  status      String
  payload     String? // Raw bridge payload (JSON)
  landedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([eventType])
  @@index([targetChain])
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

// Governance proposal state indexed from DAO contract events
model Proposal {
  id           String   @id // Contract-level proposal ID
  creator      String
  description  String
  quorum       Int
  votesFor     Int      @default(0)
  votesAgainst Int      @default(0)
  txHash       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([creator])
  @@index([createdAt])
}

enum StreamStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
  ARCHIVED // V1 stream successfully migrated to V2 — hidden from active UI
}

// RBAC roles for shared G-address organisations
enum OrgRole {
  DRAFTER // Can create and edit draft splits
  APPROVER // Can approve or reject pending splits
  EXECUTOR // Can submit approved splits to the ledger
}

// Maps a Stellar address to a role within a shared G-address organisation
model OrganizationMember {
  id            String   @id @default(cuid())
  /// The shared G-address that represents the organisation
  orgAddress    String
  /// The individual member's Stellar G-address
  memberAddress String
  role          OrgRole
  /// Who granted this membership
  addedBy       String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([orgAddress, memberAddress])
  @@index([orgAddress])
  @@index([memberAddress])
  @@index([role])
}

// API keys for 3rd-party partner dApps with elevated rate limits
model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique // SHA-256 hash of the raw key (never store plaintext)
  name       String // Human-readable label, e.g. "Acme dApp"
  owner      String // Stellar address or contact identifier
  rateLimit  Int       @default(1000) // requests per minute
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  @@index([keyHash])
  @@index([owner])
}

// Stores ledger hashes for integrity verification
model LedgerHash {
  sequence  Int      @id
  hash      String
  createdAt DateTime @default(now())
}

// Notification subscriptions — maps a Stellar address to a Discord/Telegram endpoint
model NotificationSubscription {
  id             String               @id @default(cuid())
  stellarAddress String // Receiver address to watch
  platform       NotificationPlatform // discord | telegram
  webhookUrl     String? // Discord: full webhook URL
  chatId         String? // Telegram: chat/user ID
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([stellarAddress, platform])
  @@index([stellarAddress])
  @@index([platform])
}

enum NotificationPlatform {
  discord
  telegram
}

// Invoice links for Nebula-Pay payment link generator
model InvoiceLink {
  id           String    @id @default(cuid())
  slug         String    @unique // Short UUID for shareable URL
  sender       String
  receiver     String
  amount       String // Total amount to stream
  tokenAddress String
  duration     Int // Duration in seconds
  description  String? // Optional invoice description
  pdfUrl       String? // Optional PDF invoice URL
  xdrParams    String // Encoded XDR parameters for contract call
  status       String    @default("DRAFT") // DRAFT, SIGNED, COMPLETED, EXPIRED
  expiresAt    DateTime? // Optional expiration time
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([slug])
  @@index([sender])
  @@index([status])
  @@index([createdAt])
}

// Affiliate earnings tracker for 0.5% commission on stream creation
model Affiliate {
  id             String    @id @default(cuid())
  stellarAddress String    @unique
  pendingClaim   String    @default("0") // Total unclaimed earnings in stroops
  totalEarned    String    @default("0") // Lifetime earnings
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([stellarAddress])
}

// Global protocol statistics for landing page
model GlobalStats {
  id            String   @id @default("global")
  tvlUsd        String   @default("0") // Total Value Locked in USD
  volume24hUsd  String   @default("0") // 24h volume in USD
  activeStreams Int      @default(0)
  totalStreams  Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// Daily TVL snapshots for growth charts
model TvlSnapshot {
  id        String   @id @default(cuid())
  tvlUsd    String // Total Value Locked in USD on this day
  date      DateTime @unique // Midnight UTC
  createdAt DateTime @default(now())

  @@index([date])
}

// Asset metadata from stellar.toml
model Asset {
  id            String    @id @default(cuid())
  tokenAddress  String    @unique
  homeDomain    String?
  name          String?
  symbol        String?
  imageUrl      String?
  decimals      Int       @default(7)
  isVerified    Boolean   @default(false)
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tokenAddress])
}

// Autopilot periodic split schedules
model AutopilotSchedule {
  id              String    @id @default(cuid())
  name            String
  frequency       String // cron expression, e.g. "0 9 * * 1" (every Monday 9am)
  splitConfigId   String    @map("split_config_id")
  operatorAddress String    @map("operator_address")
  minGasTankXlm   Float     @default(1.0) @map("min_gas_tank_xlm")
  isActive        Boolean   @default(true) @map("is_active")
  lastRun         DateTime? @map("last_run")
  lastTxHash      String?   @map("last_tx_hash")
  lastError       String?   @map("last_error")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([lastRun])
  @@map("AutopilotSchedule")
}

// Whitelisted assets visible in the StellarStream UI
model AssetConfig {
  id           String   @id @default(cuid())
  assetId      String   @unique // Stellar asset identifier (e.g. "USDC:GABC...")
  symbol       String
  name         String
  decimals     Int      @default(7)
  isVerified   Boolean  @default(false)
  isVisible    Boolean  @default(true)
  yieldEnabled Boolean  @default(false) @map("yield_enabled")
  iconUrl      String?  @map("icon_url")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isVerified])
  @@index([isVisible])
}

// ── V3 Fund-Split Tables ──────────────────────────────────────────────────────

// Header record for a single fund-split disbursement
model Disbursement {
  id            String   @id @default(cuid())
  senderAddress String   @map("sender_address")
  totalAmount   String   @map("total_amount")
  asset         String
  txHash        String   @unique @map("tx_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  recipients SplitRecipient[]

  @@index([senderAddress])
  @@index([txHash])
}

// Individual payout row linked to a parent Disbursement
model SplitRecipient {
  id               String       @id @default(cuid())
  disbursementId   String       @map("disbursement_id")
  recipientAddress String       @map("recipient_address")
  amount           String
  status           PayoutStatus @default(PENDING)

  disbursement Disbursement @relation(fields: [disbursementId], references: [id])

  @@index([disbursementId])
  @@index([recipientAddress])
}

enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

// Unified registry mapping Stellar Asset IDs to their source-chain equivalents
model AssetMapping {
  id             String   @id @default(cuid())
  stellarAssetId String   @unique // "SYMBOL:ISSUER" or contract address
  symbol         String
  sourceChain    String // "stellar" | "ethereum" | "polygon" | etc.
  sourceContract String? // Origin-chain contract address (null for native Stellar)
  label          String // Human-readable e.g. "USDC (Circle/Stellar)"
  bridgeProtocol String? // "wormhole" | "squid" | null for native
  decimals       Int      @default(7)
  isNative       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([symbol])
  @@index([sourceChain])
}

// Time-series price history for tax and reporting purposes
model PriceHistory {
  id         String   @id @default(cuid())
  asset      String // Asset identifier e.g. "native" or "USDC:ISSUER"
  symbol     String // Human-readable symbol e.g. "XLM", "USDC"
  priceUsd   Float // USD price at the time of recording
  source     String // "coingecko" | "dex"
  recordedAt DateTime @default(now())

  @@index([asset, recordedAt])
  @@index([recordedAt])
}

// Log of payment splits with linked USD price at time of split
model SplitLog {
  id              String    @id @default(cuid())
  streamId        String
  asset           String
  amount          String
  sender          String
  receiver        String
  txHash          String    @unique
  priceUsd        Float? // USD price at time of split
  priceSource     String? // Where the price came from
  priceRecordedAt DateTime? // When the price was recorded
  executedAt      DateTime  @default(now())

  @@index([streamId])
  @@index([executedAt])
  @@index([txHash])
}
