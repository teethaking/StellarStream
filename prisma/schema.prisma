generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

// Mirroring the Stream state from Soroban
model Stream {
  id              String       @id // The Contract ID or unique Stream ID
  sender          String
  receiver        String
  tokenAddress    String
  amountPerSecond BigInt
  totalAmount     BigInt
  status          StreamStatus @default(ACTIVE)
  endTime         DateTime?

  @@index([sender])
  @@index([receiver])
  @@index([endTime])
}

// Tracks the last synced blockchain state
model SyncState {
  id                 Int @id @default(1)
  lastLedgerSequence Int @default(0)
}

enum StreamStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

// ── V3 Fund-Split Tables ──────────────────────────────────────────────────────

// Header record for a single fund-split disbursement
model Disbursement {
  id             String             @id @default(cuid())
  senderAddress  String             @map("sender_address")
  totalAmount    String             @map("total_amount")
  asset          String
  txHash         String             @unique @map("tx_hash")
  createdAt      DateTime           @default(now()) @map("created_at")

  recipients     SplitRecipient[]

  @@index([senderAddress])
  @@index([txHash])
}

// Individual payout row linked to a parent Disbursement
model SplitRecipient {
  id               String       @id @default(cuid())
  disbursementId   String       @map("disbursement_id")
  recipientAddress String       @map("recipient_address")
  amount           String
  status           PayoutStatus @default(PENDING)

  disbursement     Disbursement @relation(fields: [disbursementId], references: [id])

  @@index([disbursementId])
  @@index([recipientAddress])
}

enum PayoutStatus {
  PENDING
  SENT
  FAILED
}